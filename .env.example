# Database (Neon Postgres)
DATABASE_URL="postgresql://user:password@host.neon.tech/arremate?sslmode=require"
DIRECT_URL="postgresql://user:password@host.neon.tech/arremate?sslmode=require"

# API
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Auth (legacy – not used when Cognito is active)
JWT_SECRET=change-me-in-production

# ─── AWS Cognito ────────────────────────────────────────────────────────────
# Shared across all environments; override per-environment in CI/CD secrets.

# The AWS region that hosts the user pool (e.g. sa-east-1)
COGNITO_REGION=sa-east-1

# The Cognito User Pool ID (format: <region>_<id>)
COGNITO_USER_POOL_ID=sa-east-1_XXXXXXXXX

# ── Public (buyer) app client ────────────────────────────────────────────────
# App client with no secret; used by the buyer-facing web app.
# Allowed flows: ALLOW_USER_SRP_AUTH, ALLOW_REFRESH_TOKEN_AUTH
COGNITO_WEB_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Admin app client ─────────────────────────────────────────────────────────
# Separate app client for the internal ops panel.
# Allowed flows: ALLOW_USER_SRP_AUTH, ALLOW_REFRESH_TOKEN_AUTH
# Restrict to ADMIN group in Cognito to enforce separation at the IdP level.
COGNITO_ADMIN_CLIENT_ID=yyyyyyyyyyyyyyyyyyyyyyyyyy

# ── Frontend (Vite) env vars ─────────────────────────────────────────────────
# These are inlined at build time via import.meta.env.VITE_*.
# Copy to apps/web/.env.local and apps/admin/.env.local as needed.

# Buyer web app
VITE_COGNITO_REGION=sa-east-1
VITE_COGNITO_USER_POOL_ID=sa-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_API_URL=http://localhost:4000

# Admin app (uses a separate Cognito client)
VITE_COGNITO_REGION=sa-east-1
VITE_COGNITO_USER_POOL_ID=sa-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=yyyyyyyyyyyyyyyyyyyyyyyyyy
VITE_API_URL=http://localhost:4000

# ── Cognito Hosted UI (OAuth2 redirect flow) ─────────────────────────────────
# Set these if using the Cognito Hosted UI instead of the custom login form.
# COGNITO_DOMAIN=arremate-dev.auth.sa-east-1.amazoncognito.com
# COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
# COGNITO_ADMIN_REDIRECT_URI=http://localhost:3001/auth/callback

# ─── Payments ─────────────────────────────────────────────────────────────────
PIX_PROVIDER=stub
# PIX_PROVIDER=production   # set in production to enable the real PIX adapter

# ─── Live Video Streaming ──────────────────────────────────────────────────────
# Select the live video backend. Use 'cloudflare_stream' in production.
# Defaults to 'stub' which is only suitable for local development and testing.
# In production this MUST be set to a real provider or the go-live endpoint will
# return a 503 error.
LIVE_VIDEO_PROVIDER=stub
# LIVE_VIDEO_PROVIDER=cloudflare_stream

# Cloudflare Stream credentials (required when LIVE_VIDEO_PROVIDER=cloudflare_stream)
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_API_TOKEN=your-cloudflare-api-token-with-stream-edit-permission
# CF_STREAM_WEBHOOK_SECRET=your-webhook-signing-secret

# ─── Observability & Error Monitoring ─────────────────────────────────────────
# Optional: set to enable Sentry error reporting.
# Create a project per surface at https://sentry.io and copy each DSN here.

# API server (Node.js) – wire in apps/api/src/server.ts when set
SENTRY_DSN=

# Buyer web app (browser) – wire in apps/web/src/main.tsx when set
VITE_WEB_SENTRY_DSN=

# Admin panel (browser) – wire in apps/admin/src/main.tsx when set
VITE_ADMIN_SENTRY_DSN=

# ─── AWS S3 (seller document uploads) ────────────────────────────────────────
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_DOCUMENTS_BUCKET=arremate-seller-documents
# URL expiry for pre-signed upload URLs (seconds)
S3_UPLOAD_URL_EXPIRY_SECONDS=300

# ─── Seed data ────────────────────────────────────────────────────────────────
# Used by `pnpm --filter @arremate/database db:seed`.
# SEED_ADMIN_EMAIL must match a Cognito user that already exists.
SEED_ADMIN_EMAIL=admin@arremate.com.br
SEED_ADMIN_COGNITO_SUB=placeholder-replace-with-real-cognito-sub
SEED_ADMIN_NAME=Admin Arremate
