generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Core domain models

model User {
  id         String   @id @default(cuid())
  cognitoSub String?  @unique
  email      String   @unique
  name       String?
  role       Role     @default(BUYER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  auctions          Auction[]          @relation("SellerAuctions")
  bids              Bid[]
  sellerApplication SellerApplication?
  sellerAccount     SellerAccount?
  auditEvents       AuditEvent[]
  shows             Show[]             @relation("SellerShows")
  inventoryItems    InventoryItem[]    @relation("SellerInventory")
  claims            Claim[]            @relation("BuyerClaims")
  buyerOrders       Order[]            @relation("BuyerOrders")
  sellerOrders      Order[]            @relation("SellerOrders")

  @@map("users")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Auction {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      AuctionStatus @default(DRAFT)
  startPrice  Decimal       @db.Decimal(12, 2)
  currentBid  Decimal?      @db.Decimal(12, 2)
  startAt     DateTime?
  endAt       DateTime?
  sellerId    String
  seller      User          @relation("SellerAuctions", fields: [sellerId], references: [id])
  bids        Bid[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("auctions")
}

enum AuctionStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model Bid {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(12, 2)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id])
  createdAt DateTime @default(now())

  @@map("bids")
}

// ─── Seller Onboarding ────────────────────────────────────────────────────────

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum DocumentType {
  IDENTITY
  ADDRESS_PROOF
  BUSINESS_REGISTRATION
  OTHER
}

model SellerApplication {
  id              String            @id @default(cuid())
  userId          String            @unique
  user            User              @relation(fields: [userId], references: [id])
  status          ApplicationStatus @default(DRAFT)

  // Business info
  businessName    String?
  businessType    String?
  taxId           String?
  phone           String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?

  // Review metadata
  reviewedById    String?
  reviewNotes     String?
  reviewedAt      DateTime?

  submittedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  documents       SellerDocument[]
  sellerAccount   SellerAccount?
  auditEvents     AuditEvent[]

  @@map("seller_applications")
}

model SellerDocument {
  id            String            @id @default(cuid())
  applicationId String
  application   SellerApplication @relation(fields: [applicationId], references: [id])
  documentType  DocumentType
  fileName      String
  s3Key         String
  contentType   String
  sizeBytes     Int?
  uploadedAt    DateTime          @default(now())

  @@map("seller_documents")
}

model SellerAccount {
  id            String            @id @default(cuid())
  userId        String            @unique
  user          User              @relation(fields: [userId], references: [id])
  applicationId String            @unique
  application   SellerApplication @relation(fields: [applicationId], references: [id])
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("seller_accounts")
}

// ─── Shows & Inventory ────────────────────────────────────────────────────────

enum ShowStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model Show {
  id          String     @id @default(cuid())
  sellerId    String
  seller      User       @relation("SellerShows", fields: [sellerId], references: [id])
  title       String
  description String?
  status      ShowStatus @default(DRAFT)
  scheduledAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  queueItems  ShowInventoryItem[]
  sessions    ShowSession[]

  @@map("shows")
}

enum ItemCondition {
  NEW
  USED
  REFURBISHED
}

model InventoryItem {
  id           String        @id @default(cuid())
  sellerId     String
  seller       User          @relation("SellerInventory", fields: [sellerId], references: [id])
  title        String
  description  String?
  condition    ItemCondition @default(NEW)
  startingPrice Decimal      @db.Decimal(12, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  images       InventoryImage[]
  showItems    ShowInventoryItem[]
  orderLines   OrderLine[]

  @@map("inventory_items")
}

model InventoryImage {
  id          String        @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  s3Key       String
  contentType String
  fileName    String
  position    Int           @default(0)
  uploadedAt  DateTime      @default(now())

  @@map("inventory_images")
}

model ShowInventoryItem {
  id              String        @id @default(cuid())
  showId          String
  show            Show          @relation(fields: [showId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  position        Int
  soldOut         Boolean       @default(false)
  createdAt       DateTime      @default(now())

  pinnedSessions  ShowSession[] @relation("PinnedSession")
  claims          Claim[]

  @@unique([showId, inventoryItemId])
  @@map("show_inventory_items")
}

// ─── Claims ───────────────────────────────────────────────────────────────────

enum ClaimStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

model Claim {
  id           String      @id @default(cuid())
  sessionId    String
  session      ShowSession @relation(fields: [sessionId], references: [id])
  buyerId      String
  buyer        User        @relation("BuyerClaims", fields: [buyerId], references: [id])
  queueItemId  String
  queueItem    ShowInventoryItem @relation(fields: [queueItemId], references: [id])
  priceAtClaim Decimal     @db.Decimal(12, 2)
  status       ClaimStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  order        Order?

  @@map("claims")
}

// ─── Orders & Payments ────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id          String      @id @default(cuid())
  claimId     String      @unique
  claim       Claim       @relation(fields: [claimId], references: [id])
  buyerId     String
  buyer       User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId    String
  seller      User        @relation("SellerOrders", fields: [sellerId], references: [id])
  status      OrderStatus @default(PENDING_PAYMENT)
  totalCents  Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lines       OrderLine[]
  payments    Payment[]

  @@map("orders")
}

model OrderLine {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  title           String
  priceCents      Int
  quantity        Int           @default(1)
  createdAt       DateTime      @default(now())

  @@map("order_lines")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  status          PaymentStatus @default(PENDING)
  provider        String        @default("pix")
  amountCents     Int
  providerId      String?
  pixCode         String?
  pixQrCodeBase64 String?
  pixExpiresAt    DateTime?
  webhookPayload  Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

// ─── Live Sessions ────────────────────────────────────────────────────────────

enum SessionStatus {
  STARTING
  LIVE
  ENDED
}

model ShowSession {
  id                String            @id @default(cuid())
  showId            String
  show              Show              @relation(fields: [showId], references: [id])
  status            SessionStatus     @default(STARTING)
  providerSessionId String?
  playbackUrl       String?
  pinnedItemId      String?
  pinnedItem        ShowInventoryItem? @relation("PinnedSession", fields: [pinnedItemId], references: [id])
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  claims            Claim[]

  @@map("show_sessions")
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditEvent {
  id            String             @id @default(cuid())
  action        String
  actorId       String
  actor         User               @relation(fields: [actorId], references: [id])
  applicationId String?
  application   SellerApplication? @relation(fields: [applicationId], references: [id])
  metadata      Json?
  createdAt     DateTime           @default(now())

  @@map("audit_events")
}
