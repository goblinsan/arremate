generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Core domain models

model User {
  id          String    @id @default(cuid())
  cognitoSub  String?   @unique
  email       String    @unique
  name        String?
  role        Role      @default(BUYER)
  activeRole  Role?
  isSuspended Boolean   @default(false)
  suspendedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auctions              Auction[]           @relation("SellerAuctions")
  bids                  Bid[]
  liveBids              LiveBid[]
  highestBidItems       ShowInventoryItem[]  @relation("ShowItemHighestBidder")
  sellerApplication     SellerApplication?
  sellerAccount         SellerAccount?
  sellerReviewsReceived SellerReview[]       @relation("SellerReviewsReceived")
  sellerReviewsWritten  SellerReview[]       @relation("SellerReviewsWritten")
  auditEvents           AuditEvent[]
  shows                 Show[]              @relation("SellerShows")
  inventoryItems        InventoryItem[]     @relation("SellerInventory")
  chatMessages          ChatMessage[]       @relation("UserChatMessages")
  claims                Claim[]             @relation("BuyerClaims")
  buyerOrders           Order[]             @relation("BuyerOrders")
  sellerOrders          Order[]             @relation("SellerOrders")
  supportTickets        SupportTicket[]     @relation("UserSupportTickets")
  raisedDisputes        Dispute[]           @relation("DisputeRaisedBy")
  resolvedDisputes      Dispute[]           @relation("DisputeResolvedBy")
  moderationCasesAbout  ModerationCase[]    @relation("ModerationCaseUser")
  moderationCasesActed  ModerationCase[]    @relation("ModerationCaseActor")
  feeOverrides          FeeSellerOverride[] @relation("SellerFeeOverrides")
  feePromotions         FeePromotion[]      @relation("SellerFeePromotions")
  issuedRefunds         OrderRefund[]       @relation("IssuedRefunds")
  settlementEntries     SettlementLedgerEntry[] @relation("SellerLedgerEntries")
  showPresences         ShowPresence[]
  payables              SellerPayable[]         @relation("SellerPayables")
  payoutEntries         PayoutEntry[]           @relation("SellerPayoutEntries")
  deviceTokens          DeviceToken[]           @relation("UserDeviceTokens")
  notificationPreference NotificationPreference?

  @@map("users")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Auction {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      AuctionStatus @default(DRAFT)
  startPrice  Decimal       @db.Decimal(12, 2)
  currentBid  Decimal?      @db.Decimal(12, 2)
  startAt     DateTime?
  endAt       DateTime?
  sellerId    String
  seller      User          @relation("SellerAuctions", fields: [sellerId], references: [id])
  bids        Bid[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("auctions")
}

enum AuctionStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model Bid {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(12, 2)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id])
  createdAt DateTime @default(now())

  @@map("bids")
}

// ─── Seller Onboarding ────────────────────────────────────────────────────────

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum DocumentType {
  IDENTITY
  ADDRESS_PROOF
  BUSINESS_REGISTRATION
  OTHER
}

model SellerApplication {
  id              String            @id @default(cuid())
  userId          String            @unique
  user            User              @relation(fields: [userId], references: [id])
  status          ApplicationStatus @default(DRAFT)

  // Business info
  businessName    String?
  businessType    String?
  taxId           String?
  phone           String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?
  brandLogoUrl    String?

  // Review metadata
  reviewedById    String?
  reviewNotes     String?
  reviewedAt      DateTime?

  submittedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  documents       SellerDocument[]
  sellerAccount   SellerAccount?
  auditEvents     AuditEvent[]

  @@map("seller_applications")
}

model SellerDocument {
  id            String            @id @default(cuid())
  applicationId String
  application   SellerApplication @relation(fields: [applicationId], references: [id])
  documentType  DocumentType
  fileName      String
  s3Key         String
  contentType   String
  sizeBytes     Int?
  uploadedAt    DateTime          @default(now())

  @@map("seller_documents")
}

model SellerAccount {
  id            String            @id @default(cuid())
  userId        String            @unique
  user          User              @relation(fields: [userId], references: [id])
  applicationId String            @unique
  application   SellerApplication @relation(fields: [applicationId], references: [id])
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("seller_accounts")
}

// ─── Shows & Inventory ────────────────────────────────────────────────────────

enum ShowStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model Show {
  id          String     @id @default(cuid())
  sellerId    String
  seller      User       @relation("SellerShows", fields: [sellerId], references: [id])
  title       String
  description String?
  status      ShowStatus @default(DRAFT)
  scheduledAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  queueItems     ShowInventoryItem[]
  sessions       ShowSession[]
  raidedSessions ShowSession[]       @relation("RaidedSessions")
  presences      ShowPresence[]

  @@map("shows")
}

enum ItemCondition {
  NEW
  USED
  REFURBISHED
}

model InventoryItem {
  id           String        @id @default(cuid())
  sellerId     String
  seller       User          @relation("SellerInventory", fields: [sellerId], references: [id])
  title        String
  description  String?
  condition    ItemCondition @default(NEW)
  startingPrice Decimal      @db.Decimal(12, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  images       InventoryImage[]
  showItems    ShowInventoryItem[]
  orderLines   OrderLine[]

  @@map("inventory_items")
}

model InventoryImage {
  id          String        @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  s3Key       String
  contentType String
  fileName    String
  position    Int           @default(0)
  uploadedAt  DateTime      @default(now())

  @@map("inventory_images")
}

model ShowInventoryItem {
  id              String        @id @default(cuid())
  showId          String
  show            Show          @relation(fields: [showId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  position        Int
  soldOut         Boolean       @default(false)
  currentBid      Decimal?      @db.Decimal(12, 2)
  highestBidderId String?
  highestBidder   User?         @relation("ShowItemHighestBidder", fields: [highestBidderId], references: [id])
  bidCount        Int           @default(0)
  createdAt       DateTime      @default(now())

  pinnedSessions  ShowSession[] @relation("PinnedSession")
  claims          Claim[]
  bids            LiveBid[]

  @@unique([showId, inventoryItemId])
  @@map("show_inventory_items")
}

// ─── Claims ───────────────────────────────────────────────────────────────────

enum ClaimStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

model Claim {
  id           String      @id @default(cuid())
  sessionId    String
  session      ShowSession @relation(fields: [sessionId], references: [id])
  buyerId      String
  buyer        User        @relation("BuyerClaims", fields: [buyerId], references: [id])
  queueItemId  String
  queueItem    ShowInventoryItem @relation(fields: [queueItemId], references: [id])
  priceAtClaim Decimal     @db.Decimal(12, 2)
  status       ClaimStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  order        Order?

  @@map("claims")
}

// ─── Orders & Payments ────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  RETURNED
}

model Order {
  id          String      @id @default(cuid())
  claimId     String      @unique
  claim       Claim       @relation(fields: [claimId], references: [id])
  buyerId     String
  buyer       User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId    String
  seller      User        @relation("SellerOrders", fields: [sellerId], references: [id])
  status      OrderStatus @default(PENDING_PAYMENT)
  totalCents  Int

  // Immutable fee snapshot — captured at order creation from live FeeConfig
  feeConfigVersionId    String?
  feeConfigVersion      Int?
  subtotalCents         Int?
  commissionBps         Int?
  commissionCents       Int?
  processorFeeBps       Int?
  processorFeeCents     Int?
  shippingCents         Int?
  buyerTotalCents       Int?
  sellerPayoutCents     Int?
  promotionCode         String?
  promotionDiscountBps  Int?
  sellerOverrideApplied Boolean?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lines          OrderLine[]
  payments       Payment[]
  shipment       Shipment?
  supportTickets SupportTicket[]
  disputes       Dispute[]
  refunds        OrderRefund[]
  ledgerEntries  SettlementLedgerEntry[]
  review         SellerReview?
  payable        SellerPayable?

  @@map("orders")
}

// ─── Order Refunds ────────────────────────────────────────────────────────────

enum RefundType {
  FULL
  PARTIAL
}

model OrderRefund {
  id                        String     @id @default(cuid())
  orderId                   String
  order                     Order      @relation(fields: [orderId], references: [id])
  issuedById                String
  issuedBy                  User       @relation("IssuedRefunds", fields: [issuedById], references: [id])
  refundType                RefundType
  refundAmountCents         Int
  commissionReversalCents   Int
  processorFeeReversalCents Int
  sellerClawbackCents       Int
  payoutOffsetCents         Int
  reason                    String?
  createdAt                 DateTime   @default(now())
  ledgerEntries             SettlementLedgerEntry[] @relation("RefundLedgerEntries")

  @@map("order_refunds")
}

model OrderLine {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  title           String
  priceCents      Int
  quantity        Int           @default(1)
  createdAt       DateTime      @default(now())

  @@map("order_lines")
}

model Payment {
  id              String           @id @default(cuid())
  orderId         String
  order           Order            @relation(fields: [orderId], references: [id])
  status          PaymentStatus    @default(PENDING)
  provider        String           @default("pix")
  amountCents     Int
  providerId      String?
  pixCode         String?
  pixQrCodeBase64 String?
  pixExpiresAt    DateTime?
  webhookPayload  Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  webhookLogs     PixWebhookLog[]

  @@map("payments")
}

// ─── Pix Webhook Audit Log ────────────────────────────────────────────────────

model PixWebhookLog {
  id             String   @id @default(cuid())
  paymentId      String?
  payment        Payment? @relation(fields: [paymentId], references: [id])
  providerId     String
  eventStatus    String
  idempotencyKey String   @unique
  rawPayload     Json
  processedAt    DateTime @default(now())

  @@index([providerId])
  @@map("pix_webhook_logs")
}

// ─── Live Sessions ────────────────────────────────────────────────────────────

enum SessionStatus {
  STARTING
  LIVE
  ENDED
}

enum IngestMode {
  NATIVE_WEBRTC
  RTMP_EXTERNAL
}

enum BroadcastHealth {
  GOOD
  DEGRADED
  DOWN
}

model ShowSession {
  id                      String            @id @default(cuid())
  showId                  String
  show                    Show              @relation(fields: [showId], references: [id])
  status                  SessionStatus     @default(STARTING)
  providerSessionId       String?
  playbackUrl             String?
  pinnedItemId            String?
  pinnedItem              ShowInventoryItem? @relation("PinnedSession", fields: [pinnedItemId], references: [id])
  raidedToShowId          String?
  raidedToShow            Show?             @relation("RaidedSessions", fields: [raidedToShowId], references: [id])
  startedAt               DateTime?
  endedAt                 DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  // Native broadcast fields (nullable for rollout safety)
  ingestMode              IngestMode?
  providerName            String?
  providerStreamId        String?
  providerInputId         String?
  providerPlaybackId      String?
  publishUrl              String?
  publishTokenExpiresAt   DateTime?
  broadcastStartedAt      DateTime?
  firstFrameAt            DateTime?
  broadcastLastHeartbeatAt DateTime?
  broadcastHealth         BroadcastHealth?
  reconnectCount          Int               @default(0)
  broadcastErrorCode      String?
  broadcastEndedReason    String?

  chatMessages      ChatMessage[]
  claims            Claim[]
  bids              LiveBid[]

  @@map("show_sessions")
}

model ShowPresence {
  id         String   @id @default(cuid())
  showId     String
  show       Show     @relation(fields: [showId], references: [id], onDelete: Cascade)
  viewerKey  String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([showId, viewerKey])
  @@index([showId, lastSeenAt])
  @@map("show_presences")
}

model SellerReview {
  id        String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerId   String
  seller     User     @relation("SellerReviewsReceived", fields: [sellerId], references: [id])
  buyerId    String
  buyer      User     @relation("SellerReviewsWritten", fields: [buyerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sellerId, createdAt])
  @@map("seller_reviews")
}

model LiveBid {
  id          String            @id @default(cuid())
  sessionId   String
  session     ShowSession       @relation(fields: [sessionId], references: [id])
  queueItemId String
  queueItem   ShowInventoryItem @relation(fields: [queueItemId], references: [id])
  bidderId    String
  bidder      User              @relation(fields: [bidderId], references: [id])
  amount      Decimal           @db.Decimal(12, 2)
  createdAt   DateTime          @default(now())

  @@index([sessionId, queueItemId, createdAt])
  @@map("live_bids")
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditEvent {
  id            String             @id @default(cuid())
  action        String
  actorId       String
  actor         User               @relation(fields: [actorId], references: [id])
  applicationId String?
  application   SellerApplication? @relation(fields: [applicationId], references: [id])
  metadata      Json?
  createdAt     DateTime           @default(now())

  @@map("audit_events")
}

// ─── Shipment ─────────────────────────────────────────────────────────────────

model Shipment {
  id                String            @id @default(cuid())
  orderId           String            @unique
  order             Order             @relation(fields: [orderId], references: [id])
  status            FulfillmentStatus @default(PENDING)
  carrier           String?
  trackingNumber    String?
  trackingUrl       String?
  estimatedDelivery DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("shipments")
}

// ─── Support Tickets ──────────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportTicket {
  id        String       @id @default(cuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id])
  userId    String
  user      User         @relation("UserSupportTickets", fields: [userId], references: [id])
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("support_tickets")
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

enum ModerationStatus {
  APPROVED
  FLAGGED
  REMOVED
}

model ChatMessage {
  id               String           @id @default(cuid())
  sessionId        String
  session          ShowSession      @relation(fields: [sessionId], references: [id])
  userId           String
  user             User             @relation("UserChatMessages", fields: [userId], references: [id])
  content          String
  moderationStatus ModerationStatus @default(APPROVED)
  createdAt        DateTime         @default(now())

  @@map("chat_messages")
}

// ─── Disputes ─────────────────────────────────────────────────────────────────

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum DisputeReason {
  ITEM_NOT_RECEIVED
  ITEM_NOT_AS_DESCRIBED
  PAYMENT_ISSUE
  OTHER
}

model Dispute {
  id           String        @id @default(cuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id])
  raisedById   String
  raisedBy     User          @relation("DisputeRaisedBy", fields: [raisedById], references: [id])
  reason       DisputeReason
  description  String?
  status       DisputeStatus @default(OPEN)
  resolvedById String?
  resolvedBy   User?         @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("disputes")
}

// ─── Moderation Cases ─────────────────────────────────────────────────────────

enum ModerationActionType {
  SELLER_STRIKE
  USER_SUSPENSION
  USER_UNSUSPENSION
}

model ModerationCase {
  id         String               @id @default(cuid())
  userId     String
  user       User                 @relation("ModerationCaseUser", fields: [userId], references: [id])
  actionType ModerationActionType
  reason     String?
  actorId    String
  actor      User                 @relation("ModerationCaseActor", fields: [actorId], references: [id])
  createdAt  DateTime             @default(now())

  @@map("moderation_cases")
}

// ─── Fee Configuration ────────────────────────────────────────────────────────

enum ShippingModel {
  INCLUDED
  PASS_THROUGH
  FIXED
}

enum FeeType {
  COMMISSION
  PROCESSOR_FEE
  SUBSCRIPTION
  PROMOTED_LISTING
  PREMIUM_SERVICE
  PAYOUT_ACCELERATION
  LOGISTICS_MARGIN
  REFUND_OFFSET
}

model FeeConfig {
  id                 String              @id @default(cuid())
  version            Int
  label              String?
  commissionBps      Int
  processorFeeBps    Int                 @default(0)
  shippingModel      ShippingModel       @default(INCLUDED)
  shippingFixedCents Int                 @default(0)
  metadata           Json?
  isActive           Boolean             @default(false)
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  sellerOverrides    FeeSellerOverride[]
  promotions         FeePromotion[]

  @@map("fee_configs")
}

model FeeSellerOverride {
  id            String    @id @default(cuid())
  feeConfigId   String
  feeConfig     FeeConfig @relation(fields: [feeConfigId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User      @relation("SellerFeeOverrides", fields: [sellerId], references: [id])
  commissionBps Int
  reason        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([feeConfigId, sellerId])
  @@map("fee_seller_overrides")
}

model FeePromotion {
  id            String     @id @default(cuid())
  feeConfigId   String?
  feeConfig     FeeConfig? @relation(fields: [feeConfigId], references: [id], onDelete: SetNull)
  code          String     @unique
  discountBps   Int
  sellerId      String?
  seller        User?      @relation("SellerFeePromotions", fields: [sellerId], references: [id])
  validFrom     DateTime
  validTo       DateTime
  maxUsages     Int?
  usageCount    Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("fee_promotions")
}

// ─── Settlement Ledger ────────────────────────────────────────────────────────
// Adjacent ledger entries for fee products that are not tied to a single order
// (e.g. subscriptions, promoted-listing charges, payout-acceleration fees).
// Order-adjacent entries (e.g. logistics margin) may optionally reference an order.

model SettlementLedgerEntry {
  id             String      @id @default(cuid())
  sellerId       String
  seller         User        @relation("SellerLedgerEntries", fields: [sellerId], references: [id])
  feeType        FeeType
  amountCents    Int
  description    String?
  orderId        String?
  order          Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderRefundId  String?
  orderRefund    OrderRefund? @relation("RefundLedgerEntries", fields: [orderRefundId], references: [id], onDelete: SetNull)
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  payoutEntry    PayoutEntry?

  @@map("settlement_ledger_entries")
}

// ─── Seller Payables ──────────────────────────────────────────────────────────
// A payable is created for each paid order, recording the seller's owed amount.
// It moves through PENDING → INCLUDED_IN_BATCH → PAID (or OFFSET for refunds).

enum PayableStatus {
  PENDING
  INCLUDED_IN_BATCH
  PAID
  OFFSET
}

model SellerPayable {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation("SellerPayables", fields: [sellerId], references: [id])
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  amountCents Int
  status      PayableStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  payoutEntry PayoutEntry?

  @@map("seller_payables")
}

// ─── Payout Batches & Entries ─────────────────────────────────────────────────
// A batch groups one or more payout entries (payables + ledger adjustments)
// for a given settlement period and is marked PAID once disbursed.

enum PayoutBatchStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

model PayoutBatch {
  id          String            @id @default(cuid())
  status      PayoutBatchStatus @default(PENDING)
  periodStart DateTime
  periodEnd   DateTime
  totalCents  Int
  notes       String?
  paidAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  entries     PayoutEntry[]

  @@map("payout_batches")
}

model PayoutEntry {
  id             String      @id @default(cuid())
  batchId        String
  batch          PayoutBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  sellerId       String
  seller         User        @relation("SellerPayoutEntries", fields: [sellerId], references: [id])
  amountCents    Int
  description    String?
  payableId      String?     @unique
  payable        SellerPayable? @relation(fields: [payableId], references: [id], onDelete: SetNull)
  ledgerEntryId  String?     @unique
  ledgerEntry    SettlementLedgerEntry? @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())

  @@map("payout_entries")
}

// ─── Mobile Device Tokens ─────────────────────────────────────────────────────

enum DevicePlatform {
  IOS
  ANDROID
}

model DeviceToken {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation("UserDeviceTokens", fields: [userId], references: [id], onDelete: Cascade)
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@map("device_tokens")
}

// ─── Notification Preferences ─────────────────────────────────────────────────

model NotificationPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showStartingSoon Boolean  @default(true)
  sellerLive       Boolean  @default(true)
  claimExpiring    Boolean  @default(true)
  paymentConfirmed Boolean  @default(true)
  orderShipped     Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("notification_preferences")
}
