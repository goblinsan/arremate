# API
EXPO_PUBLIC_API_URL=http://localhost:4000

# Cognito
EXPO_PUBLIC_COGNITO_REGION=sa-east-1
EXPO_PUBLIC_COGNITO_USER_POOL_ID=
EXPO_PUBLIC_COGNITO_CLIENT_ID=
# Hosted UI domain (e.g. myapp.auth.sa-east-1.amazoncognito.com) for OAuth/PKCE flow
EXPO_PUBLIC_COGNITO_HOSTED_UI_DOMAIN=

# Analytics (optional – leave blank to use console logging in development)
# Replace with your provider's write key / DSN when integrating
EXPO_PUBLIC_ANALYTICS_WRITE_KEY=

# Crash reporting (optional – leave blank to use console logging in development)
# Replace with your Sentry DSN or equivalent when integrating
EXPO_PUBLIC_SENTRY_DSN=
