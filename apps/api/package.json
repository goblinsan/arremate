{
  "name": "@arremate/api",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "deploy": "wrangler deploy --env production",
    "deploy:dry-run": "wrangler deploy --dry-run --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "start": "node dist/server.js",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@arremate/auth": "workspace:*",
    "@arremate/config": "workspace:*",
    "@arremate/database": "workspace:*",
    "@arremate/observability": "workspace:*",
    "@arremate/payments": "workspace:*",
    "@arremate/types": "workspace:*",
    "@arremate/video": "workspace:*",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@hono/node-server": "^2.0.0",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250522.0",
    "@types/node": "^20.12.12",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "wrangler": "^4.0.0"
  }
}
