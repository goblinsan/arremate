    "@arremate/types": "workspace:*",
    "@arremate/video": "workspace:*",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
